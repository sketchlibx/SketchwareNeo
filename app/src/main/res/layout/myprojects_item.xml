<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/img_icon_view"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginVertical="16dp"
        android:layout_marginStart="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/img_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Project Icon"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                tools:src="@drawable/sketch_app_icon" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shadow_gradient_bottom_top"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tv_published"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:text="605" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/img_pin"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginTop="-6dp"
        android:layout_marginEnd="-6dp"
        android:elevation="4dp"
        android:background="@drawable/circle_bg_surface"
        android:padding="3dp"
        app:layout_constraintEnd_toEndOf="@id/img_icon_view"
        app:layout_constraintTop_toTopOf="@id/img_icon_view"
        app:srcCompat="@drawable/ic_mtrl_pin_fill"
        app:tint="?attr/colorPrimary" />

    <TextView
        android:id="@+id/project_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintBottom_toTopOf="@+id/app_name"
        app:layout_constraintEnd_toStartOf="@id/expand"
        app:layout_constraintStart_toEndOf="@id/img_icon_view"
        app:layout_constraintTop_toTopOf="@id/img_icon_view"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Sketchware Pro Demo" />

    <TextView
        android:id="@+id/app_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintBottom_toTopOf="@+id/package_name"
        app:layout_constraintEnd_toEndOf="@id/project_name"
        app:layout_constraintStart_toStartOf="@id/project_name"
        app:layout_constraintTop_toBottomOf="@id/project_name"
        tools:text="InternalDemo (1.4)" />

    <TextView
        android:id="@+id/package_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOutline"
        app:layout_constraintBottom_toBottomOf="@id/img_icon_view"
        app:layout_constraintEnd_toEndOf="@id/project_name"
        app:layout_constraintStart_toStartOf="@id/project_name"
        app:layout_constraintTop_toBottomOf="@id/app_name"
        tools:text="com.jbk.internal.demo" />

    <ImageView
        android:id="@+id/expand"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="12dp"
        android:src="@drawable/selector_ic_expand_more_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurfaceVariant" />

</androidx.constraintlayout.widget.ConstraintLayout>
