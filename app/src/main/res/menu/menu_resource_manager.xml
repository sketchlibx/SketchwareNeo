<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Search — always visible as an icon in the toolbar -->
    <item
        android:id="@+id/menu_search"
        android:icon="@drawable/ic_search_24"
        android:title="Search"
        android:contentDescription="Search resources"
        app:showAsAction="ifRoom" />

    <!-- Sort — always visible -->
    <item
        android:id="@+id/menu_sort"
        android:icon="@drawable/ic_sort_24"
        android:title="Sort"
        android:contentDescription="Sort resources"
        app:showAsAction="ifRoom" />

    <!-- Expand all — shown only in tree-view mode (visibility toggled in code) -->
    <item
        android:id="@+id/menu_expand_all"
        android:icon="@drawable/ic_expand_all_24"
        android:title="Expand all"
        android:visible="false"
        app:showAsAction="never" />

    <!-- Collapse all — shown only in tree-view mode -->
    <item
        android:id="@+id/menu_collapse_all"
        android:icon="@drawable/ic_expand_all_24"
        android:title="Collapse all"
        android:visible="false"
        app:showAsAction="never" />

</menu>
