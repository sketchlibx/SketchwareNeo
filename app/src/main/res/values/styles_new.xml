<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.SketchwareNeo.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">?attr/colorSurfaceContainer</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.SketchwareNeo.CollapsingToolbar" parent="Widget.Material3Expressive.CollapsingToolbar.Large">
        <item name="collapsedTitleTextAppearance">@style/TextAppearance.SketchwareNeo.CollapsingToolbar.Collapsed</item>
        <item name="expandedTitleTextAppearance">@style/TextAppearance.SketchwareNeo.CollapsingToolbar.Expanded</item>
        <item name="titleCollapseMode">scale</item>
    </style>

    <style name="TextAppearance.SketchwareNeo.CollapsingToolbar.Collapsed" parent="TextAppearance.SketchwareNeo.TitleLarge" />
    <style name="TextAppearance.SketchwareNeo.CollapsingToolbar.Expanded" parent="TextAppearance.SketchwareNeo.HeadlineMedium" />

    <style name="Widget.SketchwareNeo.Toolbar.SmallText" parent="Widget.Material3Expressive.Toolbar.OnSurface">
        <item name="titleTextAppearance">?attr/textAppearanceBodyLarge</item>
    </style>

    <style name="Widget.SketchwareNeo.NavigationView.Main" parent="Widget.Material3.NavigationView">
        <item name="dividerInsetEnd">@dimen/main_drawer_horizontal_padding</item>
        <item name="dividerInsetStart">@dimen/main_drawer_horizontal_padding</item>
        <item name="itemHorizontalPadding">@dimen/main_drawer_horizontal_padding</item>
        <item name="itemIconPadding">@dimen/main_drawer_icon_padding</item>
        <item name="itemShapeInsetEnd">@dimen/main_drawer_shape_horizontal_inset</item>
        <item name="itemShapeInsetStart">@dimen/main_drawer_shape_horizontal_inset</item>
        <item name="itemTextAppearance">?attr/textAppearanceBodyMedium</item>
        <item name="subheaderInsetEnd">@dimen/main_drawer_horizontal_padding</item>
        <item name="subheaderInsetStart">@dimen/main_drawer_horizontal_padding</item>
    </style>

    <style name="Widget.SketchwareNeo.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Medium</item>
    </style>

    <style name="Widget.SketchwareNeo.TextInputLayout.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Medium</item>
    </style>

    <style name="ThemeOverlay.SketchwareNeo.ViewEditor" parent="Base.Theme.MaterialComponents.Light" />

    <style name="ThemeOverlay.SketchwareNeo.ViewEditor.Material3.Light" parent="ThemeOverlay.Material3.DynamicColors.Light" />

    <style name="ThemeOverlay.SketchwareNeo.ViewEditor.Material3.Dark" parent="ThemeOverlay.Material3.DynamicColors.Dark" />

    <style name="ThemeOverlay.SketchwareNeo.ViewEditor.Material3.NON_DYNAMIC.Light" parent="Base.Theme.Material3.Light" />

    <style name="ThemeOverlay.SketchwareNeo.ViewEditor.Material3.NON_DYNAMIC.Dark" parent="Base.Theme.Material3.Dark" />

    <style name="Preference.SketchwareNeo.SwitchPreferenceCompat" parent="Preference.SwitchPreferenceCompat.Material">
        <item name="widgetLayout">@layout/preference_widget_layout_m3_switch</item>
    </style>

    <style name="Widget.SketchwareNeo.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicator">@drawable/view_tab_indicator</item>
    </style>

    <style name="ThemeOverlay.SketchwareNeo.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/Widget.SketchwareNeo.BottomSheet.Modal</item>
    </style>

    <style name="Widget.SketchwareNeo.BottomSheet.Modal" parent="Widget.Material3.BottomSheet">
        <item name="android:elevation">0dp</item>
        <item name="backgroundTint">?attr/colorSurface</item>
    </style>

    <style name="ThemeOverlay.SketchwareNeo.AlertDialog" parent="ThemeOverlay.Material3Expressive.MaterialAlertDialog.Centered">
        <item name="android:colorBackground">?attr/colorSurfaceContainer</item>
        <item name="android:windowAnimationStyle">@style/MaterialAlertDialog.Material3.Animation</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowMinWidthMajor">65%</item>
        <item name="android:windowMinWidthMinor">98%</item>
        <item name="alertDialogStyle">@style/MaterialAlertDialog.SketchwareNeo</item>

        <item name="buttonBarButtonStyle">@style/Widget.Material3.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Material3.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.Material3.Button.TextButton.Dialog.Flush</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Material3.Button.TextButton.Dialog</item>
    </style>

    <style name="MaterialAlertDialog.SketchwareNeo" parent="MaterialAlertDialog.Material3Expressive">
        <item name="backgroundInsetBottom">8dp</item>
        <item name="backgroundInsetTop">8dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.ExtraLarge</item>
    </style>

    <style name="Widget.SketchwareNeo.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainer</item>
    </style>

    <style name="Widget.SketchwareNeo.Chip" parent="Widget.Material3.Chip.Input.Icon.Elevated">
        <item name="closeIconEnabled">false</item>
        <item name="closeIcon">@null</item>
        <item name="checkedIconEnabled">true</item>
        <item name="checkedIconTint">?attr/colorOnSecondary</item>
        <item name="checkedIcon">@drawable/ic_mtrl_done</item>
        <item name="chipBackgroundColor">?attr/colorSecondary</item>
        <item name="chipCornerRadius">90dp</item>
        <item name="android:textAppearance">@style/TextAppearance.SketchwareNeo.Chip</item>
        <item name="android:textColor">?attr/colorOnSecondary</item>
    </style>

    <style name="Widget.SketchwareNeo.Chip.ProjectPreview" parent="Widget.Material3.Chip.Suggestion">
        <item name="android:focusable">false</item>
        <item name="android:clickable">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">@null</item>
        <item name="shapeAppearance">?attr/shapeAppearanceCornerLarge</item>
    </style>

    <style name="ThemeOverlay.SketchwareNeo.Chip.ProjectPreview" parent="">
        <item name="chipStyle">@style/Widget.SketchwareNeo.Chip.ProjectPreview</item>
    </style>

    <style name="TextAppearance.SketchwareNeo.Chip" parent="TextAppearance.SketchwareNeo.BodyMedium" />

    <style name="TextAppearance.SketchwareNeo.BodyLargeEmphasized" parent="TextAppearance.SketchwareNeo.BodyLarge">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AsdEditorDialogTheme" parent="Theme.SketchwareNeo">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowSoftInputMode">stateVisible|adjustResize</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>
</resources>
